[Unit]
Description=MySQL Backup Agent
After=network.target

[Service]
Type=simple
# 若通过 Makefile 编译为了单执行文件，假设放在 /usr/local/bin 或某个部署目录
# 请根据实际情况修改下方的执行路径
ExecStart=/opt/backup-agent/backup-agent

# 主控端 API 地址 (请修改为您自己的实际暴露地址)
Environment="API_BASE=http://192.168.0.10:8000"
# 安全通信 Token (已自动填入当前配置的秘钥)
Environment="TOKEN=nxDEDIhmAWpA62s1IxJxO6_ZBZbHYFEb1tjXj9VFqHI="
# 轮询间隔 (秒)
Environment="POLL_INTERVAL=60"
# 节点名称 (不配置则默认读取本机的系统 hostname)
# Environment="HOSTNAME=db-node-01"
Restart=always
RestartSec=5
StandardOutput=syslog
StandardError=syslog
SyslogIdentifier=backup-agent

[Install]
WantedBy=multi-user.target
