# =====================================================================
# MySQL 自动物理克隆备份系统 环境变量模板配置
# 复制此文件并重命名为 .env，然后修改其中的配置值为真实环境的数据
# =====================================================================

# 1. 管理数据库配置 (必须使用异步 SQLAlchemy 驱动，如 mysql+aiomysql://)
MANAGEMENT_DB_URL=mysql+aiomysql://root:root@localhost:3306/auto_backup

# 2. 全局统一的 SSH 配置 (目标机上统一的且有 sudo 免密执行权限的用户)
GLOBAL_SSH_USER=backup_user
GLOBAL_SSH_KEY_PATH=/home/leon/.ssh/id_rsa

# 3. 全局目标数据库克隆凭证 (统一的、具有 CLONE_ADMIN 权限的 MySQL 用户)
GLOBAL_DB_USER=clone_user
GLOBAL_DB_PASSWORD=clone_password

# 4. 全局备份存储路径配置 (目标机本地与 NFS 的具体存储路径)
GLOBAL_BACKUP_DIR=/data/3306/mybackup/my3306/clone/
GLOBAL_NFS_DIR=/data/3306/mybackup/gfs/clone/

# 5. 全局 rsync 带宽同步限速 (单位为 KB/s，如 5120 为 5MB/s，10240 为 10MB/s)
GLOBAL_RSYNC_BWLIMIT=10240

# 6. 可选的报警发送设置 (动态加载自定义 MyAlarm 脚本)
# 指向您含有 MyAlarm 类的 Python 脚本的绝对路径，不配置则禁用报警发信
ALARM_SCRIPT_PATH=
# 每日异常汇总发送时间 Cron 表达式 (默认每天 23:30 触发)
EMAIL_SEND_CRON=30 23 * * *

# 7. 敏感配置对称加密密钥 (32 字节 Base64 编码的 Fernet 密钥)
# 若配置此项，则系统加载时会自动尝试用其解密数据库URL、用户名和密码字段，不配置或解密失败则回退为明文
ENCRYPTION_KEY=

# 8. 多机房 Zabbix 数据库连接字典 (明文 JSON 字符串)
# 根据被备份主机的 host_name 的机房前缀 myhostname.split('-')[0] 进行映射匹配
ZABBIX_DB_URLS={"bj": "mysql+aiomysql://zabbix:password@192.168.0.2:3306/zabbix", "sh": "mysql+aiomysql://zabbix:password@192.168.1.2:3306/zabbix"}
